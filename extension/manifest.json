{
  "manifest_version": 3,
  "name": "XActions — X/Twitter Automation Toolkit",
  "version": "1.4.0",
  "description": "X/Twitter growth: Plan-first UI (analyze → playbook → run), safe allowlist, automations on x.com tab.",
  "author": "nichxbt",
  "homepage_url": "https://github.com/nirholas/XActions",

  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "scripting",
    "contextMenus",
    "notifications",
    "tabs",
    "sidePanel",
    "webRequest"
  ],

  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.x.ai/*",
    "https://auth.x.ai/*",
    "https://accounts.x.ai/*",
    "https://console.x.ai/*",
    "https://openrouter.ai/*",
    "https://api.openai.com/*",
    "http://localhost:11434/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["content/injected.js"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content/bridge.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["content/injected.js"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ]
}
