{
  "name": "xactions-extension",
  "version": "1.4.0",
  "private": true,
  "description": "XActions Chrome MV3 extension — AI Strategist + automations on x.com",
  "scripts": {
    "build": "node build.cjs",
    "check": "node build.cjs --check-only",
    "dev": "node build.cjs --check-only",
    "popup:build": "node scripts/build-popup.mjs",
    "popup:watch": "node scripts/build-popup.mjs --watch",
    "popup:typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  }
}
